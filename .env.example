# Google Gemini API Key for accessing Gemini models
GEMINI_API_KEY=

# Firecrawl API Key for web scraping
FIRECRAWL_API_KEY=

# Slack Webhook URL for notifications
SLACK_WEBHOOK_URL=

# Database connection string for PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/mydatabase"

# Qdrant URL for vector database
QDRANT_URL=

# Qdrant API Key for authentication
QDRANT_API_KEY=

# Langchain API Key for tracing and monitoring
LANGCHAIN_API_KEY=

# Enable Langchain tracing V2
LANGCHAIN_TRACING_V2=true

# A brief description of your product's context for AI models
PRODUCT_CONTEXT="Your product is an AI-powered strategic analysis tool that helps businesses understand market trends and competitor strategies."
